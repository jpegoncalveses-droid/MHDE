# DuckDNS
DUCKDNS_DOMAIN=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token

# MHDE database
MHDE_DB_PATH=/opt/mhde/data/mhde.duckdb

# Dashboard auth
MHDE_DASHBOARD_AUTH_ENABLED=true
MHDE_DASHBOARD_USERNAME=admin
# Generate with: python -c "import hashlib; print(hashlib.sha256(b'your-password').hexdigest())"
MHDE_DASHBOARD_PASSWORD_HASH=replace-with-sha256-hash

# Optional: data source API keys
POLYGON_API_KEY=
FRED_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
