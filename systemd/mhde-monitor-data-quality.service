[Unit]
Description=MHDE monitor: per-engine ticker / symbol / bar coverage
After=network.target

[Service]
Type=oneshot
User=jpcg
WorkingDirectory=/home/jpcg/MHDE
Environment=MHDE_DB_PATH=/home/jpcg/MHDE/data/mhde.duckdb
ExecStart=/home/jpcg/MHDE/venv/bin/python main.py monitor data-quality
StandardOutput=append:/home/jpcg/MHDE/data/logs/monitor_data_quality.log
StandardError=append:/home/jpcg/MHDE/data/logs/monitor_data_quality.log
