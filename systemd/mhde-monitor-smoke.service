[Unit]
Description=MHDE monitor: end-to-end smoke (DB + active models + dashboard)
After=network.target

[Service]
Type=oneshot
User=jpcg
WorkingDirectory=/home/jpcg/MHDE
Environment=MHDE_DB_PATH=/home/jpcg/MHDE/data/mhde.duckdb
ExecStart=/home/jpcg/MHDE/venv/bin/python main.py monitor smoke
StandardOutput=append:/home/jpcg/MHDE/data/logs/monitor_smoke.log
StandardError=append:/home/jpcg/MHDE/data/logs/monitor_smoke.log
