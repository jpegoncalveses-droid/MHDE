[Unit]
Description=MHDE Daily Catalyst Queue Runner
After=network.target

[Service]
Type=oneshot
User=jpcg
Group=jpcg
WorkingDirectory=/home/jpcg/MHDE
EnvironmentFile=-/home/jpcg/MHDE/.env
ExecStart=/home/jpcg/MHDE/.claude/local_scripts/run_daily_catalyst_queue.sh
StandardOutput=journal
StandardError=journal
