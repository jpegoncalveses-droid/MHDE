# Copy to .env and fill in your keys before running.

# Required for Polygon adapter
POLYGON_API_KEY=your_polygon_key_here

# Required for Alpha Vantage adapter
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Required for the FX TwelveData fetcher (fx/data/refresh_twelvedata.py).
# Free tier: 800 calls/day; we use 24 (one per hour). Get a key at
# https://twelvedata.com — see OPERATIONS.md "FX data source migration".
TWELVEDATA_API_KEY=your_twelvedata_key_here

# SEC EDGAR and Nasdaq require no keys.
# Company IR requires no keys but some sites may block scrapers.
